# Super important to know where you are in the file system
PROMPT='%m:%~ %# '
FLOW_SHELL=$HOME/flowshell
FLOW_COMMANDS=$FLOW_SHELL/commands
export LUA_PATH="$FLOW_SHELL/nvim/?.lua"

# Load custom shell commands
for f in $FLOW_COMMANDS/*; do
  if [[ -f $f && $(basename "$f") != *.* ]]; then
     #echo "Install $f"
     source "$f"
  fi
done
