md:speak() {
    local file="${1:-i.md}"
    local filter=$2
    local voice =$3

    [[ "$file" != *.md ]] && file="${file}.md"

    if [[ ! -f "$file" ]]; then
        echo "md:speak:apple: file not found: $file" >&2
        return 1
    fi

    if [[ -n "$filter" ]]; then
       "filter:$filter" "$file" | pandoc -f markdown -t plain | "speak:$voice"
    else
       pandoc "$file" -t plain | "speak:$voice" 
    fi
}
